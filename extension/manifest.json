{
  "manifest_version": 3,
  "name": "Snout — Shadow SaaS & Auth Discovery",
  "version": "1.0.0",
  "description": "Finds shadow SaaS and auth methods; assess any vendor against the six IPSIE identity controls.",
  "permissions": ["storage", "webNavigation", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "storage": { "managed_schema": "managed_schema.json" },
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shadow SaaS & Auth",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "options_page": "options.html",
  "content_scripts": [
    { "matches": ["http://*/*", "https://*/*"], "js": ["content.js"], "run_at": "document_idle", "all_frames": false }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
