{
  "name": "snout-server",
  "version": "1.0.0",
  "private": true,
  "description": "Snout API — runs the assessment agent, persistence, and chat/catalog webhooks.",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run.ts",
    "kb:validate": "tsx eval/validate.ts",
    "kb:stats": "tsx scripts/kb-stats.ts",
    "seed:kb": "tsx scripts/seed-kb.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "morgan": "^1.10.0",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19"
  }
}
