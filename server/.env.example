# --- LLM provider ---
# "anthropic" (default) uses Anthropic's Messages API with server-side web_search.
# "openai" uses any OpenAI-compatible /v1/chat/completions endpoint.
LLM_PROVIDER=anthropic

# Anthropic (LLM_PROVIDER=anthropic). Point ANTHROPIC_BASE_URL at a proxy/gateway or
# an internal Anthropic-compatible endpoint if needed; default is the public API.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible (LLM_PROVIDER=openai). Works with OpenAI, LiteLLM, OpenRouter,
# vLLM, Ollama, etc. NOTE: no web search — assessments run with REDUCED GROUNDING
# (citations are dropped and unproven "supported"/"partial" verdicts become "unknown").
# LLM_BASE_URL is the server ROOT without a path; Snout appends /v1/chat/completions.
LLM_BASE_URL=                   # e.g. https://api.openai.com | http://localhost:11434 | http://litellm:4000
LLM_API_KEY=
LLM_MODEL=                      # e.g. gpt-4o-mini | llama3.1 | any model your endpoint serves

# --- Server ---
NODE_ENV=development            # set "production" to enforce fail-closed auth
PORT=8787
WEB_ORIGIN=http://localhost:5173   # comma-separated allowlist of browser origins
APP_BASE_URL=http://localhost:5173
DATA_DIR=./data                 # used by the default JSON store
# Persistence backend. Unset = zero-config JSON store (SINGLE-TENANT). Set a
# Postgres connection string to switch to the multi-tenant store, which scopes
# every row by tenant (TENANT_ID / the x-tenant header selects the tenant).
# Schema is auto-created on first use; see server/db/schema.sql for reference.
DATABASE_URL=                   # e.g. postgres://user:pass@host:5432/snout
TRUST_PROXY=loopback            # e.g. "1" behind one proxy, or your ingress CIDR
ENABLE_CATALOG=true             # set "false" to disable shadow-discovery (hides Discovered view + /api/catalog)
KB_DIR=                         # optional override for the knowledge-base dir (default: repo kb/)

# --- Assessment correctness passes (off by default; add latency/cost on web search) ---
VERIFY_FINDINGS=                # "true" = adversarial refutation pass demotes unproven verdicts
CHECK_CITATIONS=                # "true" = fetch cited pages (SSRF-guarded) and drop unsupported ones
CITATION_TIMEOUT_MS=6000        # per-citation fetch timeout

# --- Scheduled re-assessment (continuous monitoring; off by default) ---
REASSESS_INTERVAL_HOURS=0       # >0 enables a periodic re-assessment loop
REASSESS_STALE_HOURS=168        # re-assess apps not assessed within this window (default 7d)
REASSESS_BATCH=3                # max re-assessments per tick

# --- IdP pull-pollers (zero-touch discovery; off by default) ---
IDP_POLL_INTERVAL_MINUTES=0     # >0 enables periodic pulls
OKTA_LOG_URL=                   # e.g. https://your-org.okta.com/api/v1/logs
OKTA_API_TOKEN=                 # Okta SSWS API token (read-only)
ENTRA_TENANT_ID=                # Microsoft Entra tenant id
ENTRA_CLIENT_ID=                # app registration (client-credentials)
ENTRA_CLIENT_SECRET=            # app registration secret
# Google Workspace (service account + domain-wide delegation, read-only Reports scope).
GOOGLE_SA_CLIENT_EMAIL=         # service-account email (…iam.gserviceaccount.com)
GOOGLE_SA_PRIVATE_KEY=          # SA private key PEM (escaped \n are unescaped automatically)
GOOGLE_ADMIN_SUBJECT=           # admin user to impersonate via domain-wide delegation

# --- OIDC dashboard login (optional; all-or-nothing) ---
# When all five are set, users can sign in via your IdP and a signed session cookie
# authorizes API calls (bearer tokens still work too). Only ID-token claims are used
# for identity; no IdP tokens are stored. SESSION_SECRET must be >=32 chars in prod.
OIDC_ISSUER=                    # e.g. https://your-org.okta.com or https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=              # e.g. https://snout.example.com/auth/callback (must be registered)
OIDC_SCOPES=openid email profile
SESSION_SECRET=                 # HMAC secret for the session cookie (32+ random chars)
OIDC_ROLE_CLAIM=groups          # claim inspected for the admin value below
OIDC_ADMIN_VALUE=               # value within OIDC_ROLE_CLAIM that grants admin; unset = all users are admin
OIDC_TENANT_CLAIM=              # optional: claim whose value scopes the session to a tenant

# --- Auth (anti-anonymous; required in production) ---
API_TOKEN=                      # admin token; clients send: Authorization: Bearer <token>
API_VIEWER_TOKEN=               # optional read-only token (GET only; cannot mutate)
ALLOW_ANON=                     # set "true" ONLY if behind your own auth gateway
TENANT_ID=default               # tenant tag recorded on the audit log (single-tenant default)

# --- Resource limits (DoS / cost protection) ---
RATE_LIMIT_WINDOW_MS=900000     # 15 min
RATE_LIMIT_MAX=300              # general /api requests per window per client
ASSESS_RATE_MAX=15              # /api/assess requests per window per client
MAX_CONCURRENT_ASSESSMENTS=4    # in-flight agent runs cap
BODY_LIMIT=64kb

# --- Webhooks (each route stays 501 until its secret is set) ---
SNOUT_WEBHOOK_SECRET=              # shared HMAC secret for inbound catalog webhooks
SLACK_SIGNING_SECRET=           # from your Slack app's Basic Information page
TEAMS_SECURITY_TOKEN=           # base64 security token from the Teams outgoing webhook
