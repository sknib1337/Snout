# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=8787
WEB_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
DATA_DIR=./data

# --- Optional: protect the browser API with a bearer token ---
API_TOKEN=

# --- Webhooks (each route stays disabled until its secret is set) ---
TA_WEBHOOK_SECRET=          # shared HMAC secret for inbound catalog webhooks
SLACK_SIGNING_SECRET=       # from your Slack app's Basic Information page
TEAMS_SECURITY_TOKEN=       # base64 security token from the Teams outgoing webhook
